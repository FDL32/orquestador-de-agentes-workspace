{
  "schema_version": "1.2",
  "_migrations": [
    "1.0_to_1.1",
    "1.1_to_1.2"
  ],
  "active_profile": "host-project",
  "strictness_profile": "standard",
  "profiles": {
    "minimal": {
      "description": "Solo la superficie sensible minima",
      "write_roots": [],
      "blocked_command_patterns": []
    },
    "standard": {
      "description": "Replica la proteccion actual como default; bloquea ejecucion piped desde red",
      "write_roots": [],
      "blocked_command_patterns": [
        "curl\\s+.*\\|.*sh",
        "wget\\s+.*\\|.*sh"
      ]
    },
    "strict": {
      "description": "Endurece el guard sin bloquear superficies canonicas vivas",
      "write_roots": [],
      "blocked_command_patterns": [
        "chmod\\s+777",
        "curl\\s+.*\\|.*sh",
        "wget\\s+.*\\|.*sh",
        "eval\\s+.*base64",
        "python.*-c.*exec"
      ]
    }
  },
  "backends": {
    "kilo": {
      "executable": "kilo.exe",
      "args": [
        "run",
        "--auto"
      ],
      "discovery": {
        "method": "vscode_extension",
        "extension_glob": "kilocode.kilo-code-*",
        "binary_name": "kilo.exe",
        "path_fallback": true
      }
    },
    "codex": {
      "executable": "codex.cmd",
      "args": [
        "exec"
      ],
      "discovery": {
        "method": "path_only",
        "extension_glob": "openai.chatgpt-*",
        "binary_name": "codex.exe",
        "path_fallback": true
      }
    },
    "opencode": {
      "executable": "opencode",
      "args": [
        "run"
      ],
      "discovery": {
        "method": "path_only"
      }
    },
    "claude": {
      "executable": "claude",
      "args": [
        "-p"
      ],
      "discovery": {
        "method": "path_only"
      }
    },
    "default": {
      "executable": "",
      "args": [],
      "discovery": {
        "method": "path_only"
      }
    }
  },
  "role_assignments": {
    "BUILDER": "opencode",
    "MANAGER": "opencode",
    "SUPERVISOR": "default"
  },
  "role_models": {
    "BUILDER": "opencode-go/deepseek-v4-flash",
    "MANAGER": "openai/gpt-5.5"
  },
  "manager_review": {
    "timeout_seconds": 180,
    "max_attempts": 8,
    "retry_backoff_multiplier": 2.0,
    "human_gate_timeout_seconds": 86400
  },
  "skill_allowlists": {
    "BUILDER": [
      "/impl",
      "/implement",
      "/tdd",
      "/test",
      "/debug",
      "/refactor",
      "/fix"
    ],
    "MANAGER": [
      "/review",
      "/audit",
      "/validate",
      "/inspect",
      "/compare"
    ],
    "SUPERVISOR": [
      "/orchestrate",
      "/schedule",
      "/archive",
      "/report"
    ]
  }
}
