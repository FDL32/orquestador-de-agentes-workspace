import os
import re
import shutil
import tempfile
import uuid
from pathlib import Path

import pytest


PROJECT_ROOT = Path(__file__).resolve().parents[1]
RUNTIME_ROOT = PROJECT_ROOT / '.runtime' / 'test_runtime'
_SESSION_ID = uuid.uuid4().hex
_SESSION_TMP_ROOT = RUNTIME_ROOT / _SESSION_ID
_PYTEST_TMP_ROOT = _SESSION_TMP_ROOT / 'pytest'
_TEMPFILE_ROOT = _SESSION_TMP_ROOT / 'tempfile'


def _safe_name(value: str) -> str:
    return re.sub(r'[^A-Za-z0-9_.-]+', '_', value).strip('._') or 'tmp'


class ManualTempPathFactory:
    def __init__(self, base_temp: Path):
        self._base_temp = base_temp
        self._counter = 0
        self._base_temp.mkdir(parents=True, exist_ok=True)

    def getbasetemp(self) -> Path:
        return self._base_temp

    def mktemp(self, basename: str, numbered: bool = True) -> Path:
        base_name = _safe_name(basename)
        if numbered:
            self._counter += 1
            target = self._base_temp / f'{base_name}_{self._counter:04d}'
        else:
            target = self._base_temp / base_name
        target.mkdir(parents=True, exist_ok=True)
        return target


def pytest_configure(config):
    _PYTEST_TMP_ROOT.mkdir(parents=True, exist_ok=True)
    _TEMPFILE_ROOT.mkdir(parents=True, exist_ok=True)
    tempfile.tempdir = str(_TEMPFILE_ROOT)


@pytest.fixture(scope='session')
def tmp_path_factory():
    return ManualTempPathFactory(_PYTEST_TMP_ROOT)


@pytest.fixture
def tmp_path(tmp_path_factory, request):
    return tmp_path_factory.mktemp(_safe_name(request.node.name))


@pytest.fixture(autouse=True)
def restore_cwd():
    original_cwd = Path.cwd()
    try:
        yield
    finally:
        try:
            os.chdir(original_cwd)
        except (FileNotFoundError, PermissionError, OSError):
            os.chdir(PROJECT_ROOT)


def pytest_sessionfinish(session, exitstatus):
    try:
        os.chdir(PROJECT_ROOT)
    except OSError:
        pass
    shutil.rmtree(_SESSION_TMP_ROOT, ignore_errors=True)
