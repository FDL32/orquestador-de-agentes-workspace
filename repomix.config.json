{
  "output": {
    "style": "xml",
    "compress": true,
    "fileSummary": true,
    "directoryStructure": true,
    "removeComments": false,
    "showLineNumbers": false,
    "copyToClipboard": false,
    "includeEmptyDirectories": false
  },
  "include": [
    "bus/**",
    "runtime/**",
    "scripts/**",
    "agent_system/**",
    "prompts/**",
    "skills/**",
    "docs/**",
    "*.md",
    "pyproject.toml",
    "pytest.ini"
  ],
  "ignore": {
    "useGitignore": true,
    "customPatterns": [
      "*.lock",
      "*.sum",
      "package-lock.json",
      "uv.lock",
      "node_modules/",
      ".git/",
      ".venv/",
      "__pycache__/",
      "*.pyc",
      ".ruff_cache/",
      ".cache/",
      ".uv-cache/",
      ".pytest_cache/",
      ".tmp/",
      ".tmp/**",
      ".agent/runtime/",
      ".agent/collaboration/_archive/",
      ".agent/collaboration/archive/"
    ]
  }
}
